{
  "name": "class-bank",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "dev:all": "node -e \"const{spawn}=require('child_process');const s=spawn('node',['server/index.mjs'],{stdio:'inherit'});const v=spawn('npx',['vite'],{stdio:'inherit'});process.on('exit',()=>{s.kill();v.kill()})\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "canvg": "^4.0.3",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.487.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.1.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.0.0"
  }
